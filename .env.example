# Copy to .env and fill in real values. Never commit .env.
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentiq
REDIS_URL=redis://localhost:6379
# REQUIRED: Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
# This value MUST be changed before running the server. The server will refuse
# to start if this default is used (except in APP_ENV=test).
# REQUIRED before `docker compose up` — replace with a 32+ char secret.
# THIS MUST BE CHANGED; the server refuses to start with this default value.
JWT_SECRET=changeme_min32chars_replace_this
USE_MOCK_GMAIL=true

# Optional: override cost limit (default 0.50 USD per run)
COST_LIMIT_USD=0.50
# Optional: override default model
DEFAULT_MODEL=claude-sonnet-4-6
# Environment: set to 'test' in CI to bypass the JWT_SECRET guard
APP_ENV=development
