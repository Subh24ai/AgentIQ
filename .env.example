# Copy to .env and fill in real values. Never commit .env.
ANTHROPIC_API_KEY=
TAVILY_API_KEY=
SUPABASE_URL=
SUPABASE_ANON_KEY=
REDIS_URL=redis://localhost:6379
# REQUIRED before first run. Generate with:
# python3 -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=             # Required: run -> python3 -c "import secrets; print(secrets.token_hex(32))" <- and paste result here
USE_MOCK_GMAIL=true

# DEV-only login passwords (hashed at startup with bcrypt). Replace with real auth in prod.
DEV_ADMIN_PASSWORD=agentiq_admin
DEV_REVIEWER_PASSWORD=agentiq_review

# Optional: override cost limit (default 0.50 USD per run)
COST_LIMIT_USD=0.50
# Optional: override default model
DEFAULT_MODEL=claude-sonnet-4-6
# Environment: set to 'test' in CI to bypass the JWT_SECRET guard
APP_ENV=development
